{% extends "layouts/base.njk" %}
{% from "partials/sections/hero-hotlines.njk" import heroWithHotlines %}
{% from "partials/sections/intro.njk" import introSection %}
{% from "partials/sections/quote.njk" import quoteSection %}
{% from "partials/sections/search-filters.njk" import searchFiltersSection %}
{% from "partials/sections/results-grid.njk" import resultsGridSection %}
{% from "partials/sections/dedicated-list.njk" import dedicatedListSection %}
{% from "partials/sections/faq.njk" import faqSection %}

{% block header %}
  {% include "partials/header.njk" %}
{% endblock %}

{% block content %}
  {% set heroConfig = {
    left: {
      pill: { icon: "fas fas-shield-heart", text: "Akut stöd" },
      stat: { icon: "far far-handshake", text: "Dela med den drabbade" },
      title: "Ring om läget är akut",
      description: "Säkra numret till dig själv och dela det med den du stöttar. Samtal är anonyma och gratis.",
      highlights: [
        { icon: "fas fas-user-lock", title: "Alltid anonymt", text: "Ingen ser ditt nummer och samtalen är kostnadsfria." },
        { icon: "fas fas-people-group", title: "Stöd till anhöriga", text: "Flera linjer kan prata direkt med dig som närstående." },
        { icon: "fas fas-calendar-check", title: "Öppet alla dagar", text: "Hjälp även kvällar, helger och storhelger." }
      ]
    },
    right: {
      pill: { icon: "fas fas-compass", text: "Vad du hittar här" },
      title: "Snabb väg till stöd för anhöriga",
      items: [
        "Linjer som lyssnar på dig som närstående.",
        "Sök på oro, våld, missbruk eller sorg.",
        "Klickbara telefonnummer och länkar.",
        "Tips på var du kan få råd och avlastning."
      ],
      tags: [
        { icon: "fas fas-people-arrows", text: "Anhörig" },
        { icon: "fas fas-ribbon", text: "Sorg & suicid" },
        { icon: "fas fas-child-reaching", text: "Föräldrar" }
      ]
    }
  } %}
  {{ heroWithHotlines(heroConfig) }}

  {% set introParagraphs = [
    "Att stå bredvid någon som mår dåligt, lever med beroende eller befinner sig i kris tär på orken. Här hittar du stödlinjer som vänder sig direkt till anhöriga.",
    "Alla linjer är gratis och anonyma. Om du eller någon i din närhet är i omedelbar fara: ring alltid <strong>112</strong>."
  ] %}
  {{ introSection("Du som är anhörig behöver också stöd", introParagraphs) }}

  {{ quoteSection() }}

  {{ searchFiltersSection("Sök efter t.ex. anhörig, sorg, våld..", ["21 linjer", "6 kategorier"]) }}

  {{ resultsGridSection() }}

  {% set dedicatedData = {
    title: "Stöd som vänder sig till anhöriga",
    paragraphs: [
      "Att vara närstående kan vara tungt, frustrerande och ensamt. Du har rätt till stöd och avlastning."
    ],
    listIntro: "Några linjer som lyssnar på dig:",
    items: [
      "<strong>Anhöriglinjen</strong> – råd och stöd när du stöttar någon med sjukdom, funktionsnedsättning eller beroende.",
      "<strong>SPES stödlinje</strong> – prata med andra som förlorat någon i suicid.",
      "<strong>Föräldralinjen</strong> – stöd till dig som är orolig för ett barn eller en ung person.",
      "<strong>Al-Anon Familjegrupper</strong> – gemenskap för anhöriga till alkoholister, med möten även online."
    ],
    footer: "Information om telefontider och kontaktvägar kan förändras. Kontrollera alltid aktuella uppgifter på respektive organisations webbplats."
  } %}
  {{ dedicatedListSection(dedicatedData) }}

  {{ faqSection(false) }}
{% endblock %}
